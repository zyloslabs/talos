# ─── Talos Environment Configuration ─────────────────────────────────────────
#
# Copy this file to ~/.talos/.env and fill in the values.
# Keys containing SECRET, TOKEN, KEY, PASSWORD, or PAT are masked in the Admin UI.
#
# ─── Authentication ──────────────────────────────────────────────────────────

# Required for GitHub Copilot device auth flow
GITHUB_CLIENT_ID=

# GitHub Personal Access Token — used by the discovery engine to fetch repository
# content via the GitHub API when no per-application vault PAT is configured.
# Shared with openzigs. Requires at least read:org + repo scopes.
GITHUB_PERSONAL_ACCESS_TOKEN=

# ─── AI / Embeddings ────────────────────────────────────────────────────────

# OpenAI API key for embeddings (optional if using Copilot SDK for generation)
OPENAI_API_KEY=

# Brave Search API key — enables the web-search tool (https://api.search.brave.com)
# Shared with openzigs.
BRAVE_API_KEY=

# ─── Security ───────────────────────────────────────────────────────────────

# Admin API bearer token (optional — set to secure the admin API)
TALOS_ADMIN_TOKEN=

# ─── Server ─────────────────────────────────────────────────────────────────

# Port for the Talos backend server (default: 3000)
PORT=3000

# Data directory (default: ~/.talos)
# TALOS_DATA_DIR=~/.talos

# ─── Filesystem Access ──────────────────────────────────────────────────────

# Comma-separated list of directories the filesystem tool can access
# TALOS_ALLOWED_DIRS=/Users/me/projects,/tmp/talos-scratch
