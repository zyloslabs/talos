{
  "name": "talos",
  "version": "0.1.0",
  "description": "Talos: Test Automation & Logic Orchestration System - Autonomous E2E testing engine",
  "type": "module",
  "private": true,
  "license": "FSL-1.1-MIT",
  "author": "Zylos Labs LLC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zyloslabs/talos.git"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:clean": "bash scripts/dev-clean.sh",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.2.0",
    "@lancedb/lancedb": "^0.27.1",
    "@playwright/test": "^1.52.0",
    "better-sqlite3": "^12.6.2",
    "cron-parser": "^5.5.0",
    "express": "^5.2.1",
    "nanoid": "^5.1.6",
    "socket.io": "^4.8.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.57.2",
    "prettier": "^3.8.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
